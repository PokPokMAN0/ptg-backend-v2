// =============================================================================
// Prime Tech Gallery — schema.prisma (v4.0 — Dual-Database Architecture)
// PostgreSQL + Prisma ORM
//
// ARCHITECTURE NOTE:
// This database is the SECURE OPERATIONAL CORE. It stores users, auth, sensitive
// inventory (IMEIs, costs), transactions, and suppliers.
//
// Product catalog (names, specs, images, search) lives in the Catalog Engine
// (MongoDB + Meilisearch). The two systems are linked via `catalog_id`, which
// is the MongoDB _id of the product document (e.g. "6a0cbd95da32579c61b5b1b8").
//
// The `CatalogRef` model is a lightweight read-only cache of key catalog fields.
// It exists solely for SQL reporting and joins — it is NOT the source of truth.
// The Catalog Engine always wins. Sync it via POST /v1/admin/catalog-ref/sync.
// =============================================================================

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// =============================================================================
// ENUMS
// =============================================================================

enum Role {
  SUPER_ADMIN  // Can do everything including manage other ADMINs
  ADMIN        // Full CRUD on products, inventory, reports
  SALESMAN     // POS access only — no pricing edits, no cost visibility
  CUSTOMER     // Web storefront access
}

enum InventoryStatus {
  AVAILABLE    // On shelf, ready to sell
  SOLD         // Linked to a completed SaleItem
  DEFECTIVE    // Failed QC or returned broken
  RETURNED     // Customer-returned, pending inspection
  RESERVED     // Held for a pending web order (future use)
}

enum UnitCondition {
  NEW          // Factory sealed
  OPEN_BOX     // Opened but unused
  REFURBISHED  // Tested and restored
}

enum PaymentMethod {
  CASH
  CARD
  MOBILE_BANKING  // bKash, Nagad, Rocket, etc.
  BANK_TRANSFER
}

enum SaleSource {
  POS  // In-store, processed by a Salesman
  WEB  // Online order, self-service
}

enum SaleStatus {
  PENDING     // Web order placed, not yet paid
  PAID        // Payment confirmed
  PROCESSING  // Preparing for shipment (web only)
  SHIPPED     // Dispatched (web only)
  COMPLETED   // Delivered / POS transaction done
  CANCELLED
  REFUNDED
}

enum AddressType {
  SHIPPING
  BILLING
}

enum WarrantyStatus {
  ACTIVE
  EXPIRED
  CLAIMED   // A warranty service has been initiated
  VOID      // Voided due to damage/tampering
}

// =============================================================================
// SECTION 1 — USERS & RBAC
// The complete identity layer. Handles customers, staff, and admins.
// =============================================================================

model User {
  id              String    @id @default(uuid()) @db.Uuid
  email           String    @unique
  password_hash   String    // Argon2id — never store plaintext
  name            String
  phone           String?   @unique
  image_url       String?   // CDN URL for profile picture
  role            Role      @default(CUSTOMER)
  is_active       Boolean   @default(true)   // Soft-disable accounts without deleting
  is_verified     Boolean   @default(false)  // Email verification flag
  verification_expires_at DateTime?
  last_login_at   DateTime?
  created_at      DateTime  @default(now())
  updated_at      DateTime  @updatedAt

  /// JSONB bucket for non-queryable fluid data only.
  /// e.g. { "ui_preferences": { "theme": "dark" }, "notification_settings": { "sms": true } }
  /// DO NOT store cart, wishlist, or addresses here — use relational tables.
  metadata        Json?     @db.JsonB

  // Relations
  addresses         Address[]
  sales_as_buyer    Sale[]          @relation("BuyerSales")
  sales_as_salesman Sale[]          @relation("SalesmanSales")
  refresh_tokens    RefreshToken[]
  audit_logs        AuditLog[]
  cart_items        CartItem[]
  wishlist_items    WishlistItem[]
  inventory_batches InventoryBatch[] // Admin who recorded the purchase batch
  otp_codes         OtpCode[]

  @@index([email])
  @@index([phone])
  @@index([role])
  @@map("users")
}

model Address {
  id          String      @id @default(uuid()) @db.Uuid
  user_id     String      @db.Uuid
  type        AddressType @default(SHIPPING)

  label       String?   // "Home", "Office", etc.
  recipient   String
  phone       String
  line_1      String
  line_2      String?
  city        String
  district    String
  division    String?
  postal_code String?
  country     String    @default("Bangladesh")
  is_default  Boolean   @default(false)

  created_at  DateTime  @default(now())

  user        User      @relation(fields: [user_id], references: [id], onDelete: Cascade)
  sales       Sale[]    // A web order references a shipping address

  @@index([user_id])
  @@map("addresses")
}

// =============================================================================
// SECTION 2 — AUTHENTICATION & SECURITY
// =============================================================================

model RefreshToken {
  id          String    @id @default(uuid()) @db.Uuid
  user_id     String    @db.Uuid
  token_hash  String    @unique  // SHA-256 hash of the raw token. NEVER store raw.
  expires_at  DateTime
  revoked     Boolean   @default(false)
  ip_address  String?   // IP that issued this token
  user_agent  String?   // Browser/client that issued this token
  created_at  DateTime  @default(now())

  user        User      @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id])
  @@index([expires_at]) // For cleanup jobs: DELETE FROM refresh_tokens WHERE expires_at < NOW()
  @@map("refresh_tokens")
}

/// Immutable event log. Records every sensitive action across the system.
/// Written by audit.service.ts. Never deleted. Grow-only table.
model AuditLog {
  id           String   @id @default(uuid()) @db.Uuid
  actor_id     String   @db.Uuid
  action       String
  // Action naming convention: RESOURCE_VERB
  // Examples: IMEI_VIEWED, INVENTORY_UNIT_CREATED, SALE_COMPLETED,
  //           USER_ROLE_CHANGED, BATCH_DELETED, CATALOG_REF_SYNCED

  target_table String   // e.g. "inventory_units", "sales", "users"
  target_id    String   // UUID of the affected record (String for flexibility)
  metadata     Json?    @db.JsonB  // { before: {...}, after: {...} } snapshot
  ip_address   String?
  created_at   DateTime @default(now())

  actor        User     @relation(fields: [actor_id], references: [id])

  @@index([actor_id])
  @@index([action])
  @@index([target_table, target_id])
  @@index([created_at])
  @@map("audit_logs")
}

// =============================================================================
// SECTION 3 — CATALOG REFERENCE (PostgreSQL Mirror of MongoDB Catalog Engine)
//
// WHY THIS EXISTS:
// The Catalog Engine (MongoDB) is the source of truth for all product data.
// However, SQL reports (e.g. "top 5 products by revenue") need to JOIN inventory
// and sales data with a product name — without making HTTP calls to MongoDB at
// query time. This table caches the minimum fields needed for reporting.
//
// SYNC RULE:
// - Populated/updated when a product is created or updated in the Catalog Engine.
// - Never edited directly via admin UI. Edit in Catalog Engine first, then sync.
// - `catalog_id` is the MongoDB _id string — the universal link between both DBs.
// =============================================================================

model CatalogRef {
  id          String   @id @default(uuid()) @db.Uuid

  /// The MongoDB _id from the Catalog Engine. The universal foreign key.
  /// Example: "6a0cbd95da32579c61b5b1b8"
  catalog_id  String   @unique

  // Cached fields — for reporting and human-readable joins only
  sku         String   @unique
  name        String
  brand       String
  category    String   // category.primary from Catalog Engine
  retail_mrp  Decimal  @db.Decimal(12, 2)  // Cached MRP for reference

  synced_at   DateTime @default(now()) @updatedAt
  // Last sync from Catalog Engine. If stale, treat as potentially outdated.

  // Relations
  inventory_units InventoryUnit[]
  cart_items      CartItem[]
  wishlist_items  WishlistItem[]

  @@index([brand])
  @@index([category])
  @@index([catalog_id])
  @@map("catalog_refs")
}

// =============================================================================
// SECTION 4 — SUPPLIERS & PURCHASE BATCHES
//
// Supplier = vendor (distributor, importer, brand rep).
// InventoryBatch = one purchase event from one supplier (one invoice).
// All units bought on the same invoice belong to the same batch.
// This gives a full paper trail: who sold what, when, and at what cost.
// =============================================================================

model Supplier {
  id            String   @id @default(uuid()) @db.Uuid
  name          String
  phone         String?
  email         String?
  company_name  String?
  address       String?
  notes         String?  @db.Text
  is_active     Boolean  @default(true)
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  batches       InventoryBatch[]

  @@index([name])
  @@map("suppliers")
}

/// One purchase event = one InventoryBatch.
/// Groups all units bought together on a single invoice from a single supplier.
model InventoryBatch {
  id              String    @id @default(uuid()) @db.Uuid
  supplier_id     String    @db.Uuid
  recorded_by_id  String    @db.Uuid  // The Admin who entered this batch

  invoice_number  String              // Supplier's invoice/bill number
  purchase_date   DateTime            // Date of actual purchase (not created_at)
  total_cost      Decimal?  @db.Decimal(14, 2)  // Total invoice value (for reconciliation)
  currency        String    @default("BDT")
  notes           String?   @db.Text  // e.g. "Customs cleared at Chittagong port"

  created_at      DateTime  @default(now())
  updated_at      DateTime  @updatedAt

  supplier        Supplier  @relation(fields: [supplier_id],    references: [id])
  recorded_by     User      @relation(fields: [recorded_by_id], references: [id])
  units           InventoryUnit[]

  @@unique([supplier_id, invoice_number])  // One invoice number per supplier
  @@index([supplier_id])
  @@index([purchase_date])
  @@map("inventory_batches")
}

// =============================================================================
// SECTION 5 — THE VAULT (Secure Inventory)
//
// One InventoryUnit = one physical box in the showroom.
// Sensitive fields (IMEI, serial) are AES-256-GCM encrypted at application layer.
// Hash fields (HMAC-SHA256) allow fast barcode scan lookups without decrypting.
//
// CRITICAL: dealer_cost is ADMIN-only. The service layer must NEVER select
// this field for SALESMAN or CUSTOMER scoped queries.
// =============================================================================

model InventoryUnit {
  id              String          @id @default(uuid()) @db.Uuid

  /// FK to CatalogRef — links this physical unit to its catalog product.
  /// Use catalog_ref.catalog_id to call the Catalog Engine API.
  catalog_ref_id  String          @db.Uuid

  /// FK to the purchase batch this unit arrived with.
  batch_id        String?          @db.Uuid

  // ── Sensitive hardware identifiers ────────────────────────────────────────
  // AES-256-GCM encrypted at application layer (encryption.service.ts).
  // Raw plaintext NEVER enters this database.
  imei_1          String?         @unique  // Ciphertext (primary IMEI)
  imei_2          String?         @unique  // Ciphertext (secondary IMEI / dual-SIM)
  serial_number   String?         @unique  // Ciphertext
  mac_address     String?                  // Not sensitive, stored plain

  // ── Deterministic HMAC-SHA256 hashes ─────────────────────────────────────
  // For barcode scan lookups. Same plaintext + secret always produces same hash.
  // See security.service.ts → hashField()
  imei_1_hash     String?         @unique
  imei_2_hash     String?         @unique
  serial_hash     String?         @unique

  // ── Financials (ADMIN-only) ───────────────────────────────────────────────
  dealer_cost     Decimal         @db.Decimal(12, 2)  // What we paid (purchase price)

  // ── Physical state ────────────────────────────────────────────────────────
  status          InventoryStatus @default(AVAILABLE)
  condition       UnitCondition   @default(NEW)
  notes           String?         @db.Text  // e.g. "Box slightly dented"

  created_at      DateTime        @default(now())
  updated_at      DateTime        @updatedAt

  // Relations
  catalog_ref     CatalogRef      @relation(fields: [catalog_ref_id], references: [id])
  batch           InventoryBatch?  @relation(fields: [batch_id],        references: [id])
  sale_item       SaleItem?       // 1:1 — sold exactly once, ever
  warranty        Warranty?       // 1:1 — warranty issued at point of sale

  @@index([catalog_ref_id])
  @@index([batch_id])
  @@index([status])
  @@index([catalog_ref_id, status])  // "How many iPhone 17 Pro Maxes are AVAILABLE?"
  @@index([imei_1_hash])
  @@index([imei_2_hash])
  @@index([serial_hash])
  @@map("inventory_units")
}

// =============================================================================
// SECTION 6 — CART & WISHLIST
// =============================================================================

/// Server-side cart for authenticated CUSTOMERS only.
/// Guest/POS carts are client-side (Zustand) and never persisted here.
model CartItem {
  id              String     @id @default(uuid()) @db.Uuid
  user_id         String     @db.Uuid
  catalog_ref_id  String     @db.Uuid
  quantity        Int        @default(1)
  added_at        DateTime   @default(now())

  user            User       @relation(fields: [user_id],        references: [id], onDelete: Cascade)
  catalog_ref     CatalogRef @relation(fields: [catalog_ref_id], references: [id])

  @@unique([user_id, catalog_ref_id])  // One row per product per user. UPDATE quantity instead of INSERT.
  @@map("cart_items")
}

model WishlistItem {
  id              String     @id @default(uuid()) @db.Uuid
  user_id         String     @db.Uuid
  catalog_ref_id  String     @db.Uuid
  added_at        DateTime   @default(now())

  user            User       @relation(fields: [user_id],        references: [id], onDelete: Cascade)
  catalog_ref     CatalogRef @relation(fields: [catalog_ref_id], references: [id])

  @@unique([user_id, catalog_ref_id])
  @@map("wishlist_items")
}

// =============================================================================
// SECTION 7 — TRANSACTIONS & SALES
// =============================================================================

model Sale {
  id                  String        @id @default(uuid()) @db.Uuid
  buyer_id            String?       @db.Uuid   // Null for walk-in POS guests
  salesman_id         String?       @db.Uuid   // Null for web self-service orders
  shipping_address_id String?       @db.Uuid   // Only populated for web orders

  total_amount        Decimal       @db.Decimal(12, 2)
  discount_total      Decimal       @default(0) @db.Decimal(12, 2)
  tax_total           Decimal       @default(0) @db.Decimal(12, 2)
  payment_method      PaymentMethod
  source              SaleSource
  status              SaleStatus    @default(PENDING)

  /// Walk-in POS guest info. Null when buyer_id is set.
  /// Shape: { "name": "Rahim Uddin", "phone": "01712345678" }
  customer_info       Json?         @db.JsonB

  /// Payment gateway reference ID (bKash TrxID, SSLCommerz val_id, etc.)
  payment_reference   String?

  notes               String?       @db.Text

  created_at          DateTime      @default(now())
  updated_at          DateTime      @updatedAt

  buyer             User?     @relation("BuyerSales",    fields: [buyer_id],            references: [id])
  salesman          User?     @relation("SalesmanSales", fields: [salesman_id],          references: [id])
  shipping_address  Address?  @relation(               fields: [shipping_address_id],  references: [id])
  items             SaleItem[]

  @@index([buyer_id])
  @@index([salesman_id])
  @@index([status])
  @@index([source])
  @@index([created_at])
  @@map("sales")
}

/// One SaleItem = one physical box sold.
/// @unique on inventory_unit_id is the most critical constraint in the entire system.
/// It makes it IMPOSSIBLE at the database level to sell the same IMEI twice —
/// even if there is a bug in application logic.
model SaleItem {
  id                  String        @id @default(uuid()) @db.Uuid
  sale_id             String        @db.Uuid
  inventory_unit_id   String        @unique @db.Uuid  // ONE UNIT. ONE SALE. FOREVER.

  unit_price          Decimal       @db.Decimal(12, 2)  // MRP snapshot at time of sale
  discount            Decimal       @default(0) @db.Decimal(12, 2)
  tax                 Decimal       @default(0) @db.Decimal(12, 2)
  sale_price          Decimal       @db.Decimal(12, 2)  // unit_price - discount + tax
  dealer_cost         Decimal?      @db.Decimal(12, 2)  // Cost snapshot (ADMIN only)
  profit              Decimal?      @db.Decimal(12, 2)  // sale_price - dealer_cost

  sale                Sale          @relation(fields: [sale_id],             references: [id])
  inventory_unit      InventoryUnit @relation(fields: [inventory_unit_id],   references: [id])
  warranty            Warranty?

  @@index([sale_id])
  @@map("sale_items")
}

// =============================================================================
// SECTION 8 — WARRANTY TRACKING
//
// Every smartphone/device sold gets a warranty record.
// Linked to both the physical unit (InventoryUnit) and the sale line (SaleItem).
// =============================================================================

model Warranty {
  id                  String         @id @default(uuid()) @db.Uuid
  inventory_unit_id   String         @unique @db.Uuid  // 1:1
  sale_item_id        String         @unique @db.Uuid  // 1:1

  duration_months     Int            // e.g. 12 for a 1-year warranty
  starts_at           DateTime       @default(now())
  expires_at          DateTime       // starts_at + duration_months (calculated in service layer)
  warrantor           String         // e.g. "Apple International", "Prime Tech Gallery"
  status              WarrantyStatus @default(ACTIVE)
  notes               String?        @db.Text

  created_at          DateTime       @default(now())
  updated_at          DateTime       @updatedAt

  inventory_unit      InventoryUnit  @relation(fields: [inventory_unit_id], references: [id])
  sale_item           SaleItem       @relation(fields: [sale_item_id],      references: [id])

  @@index([expires_at])   // "Show me all warranties expiring this month"
  @@index([status])
  @@map("warranties")
}

// =============================================================================
// OTP CODES (Email verification & password reset)
// =============================================================================
model OtpCode {
  id          String   @id @default(uuid()) @db.Uuid
  user_id     String   @db.Uuid
  code_hash   String                            // SHA-256 hash of the 6-digit OTP
  type        OtpType                           // what this OTP is for
  expires_at  DateTime
  used        Boolean  @default(false)
  created_at  DateTime @default(now())

  user        User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id])
  @@index([expires_at])
  @@map("otp_codes")
}

enum OtpType {
  EMAIL_VERIFICATION
  PASSWORD_RESET
}